# Port Configuration
PORT=5000

# MongoDB Connection String (e.g. from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/event-media?retryWrites=true&w=majority

# JWT Token Secret Key (Any secure long string)
JWT_SECRET=your_super_secret_jwt_key_here

# Storage Provider: "local" (uses disk folder) or "azure" (uses Azure Blob Storage)
STORAGE_PROVIDER=local

# Azure Blob Storage (Required only if STORAGE_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_STORAGE_CONTAINER_NAME=event-media

# Azure Cognitive Services APIs
AZURE_FACE_KEY=your_azure_face_api_key
AZURE_FACE_ENDPOINT=https://your_face_resource.cognitiveservices.azure.com/face/v1.0
AZURE_VISION_KEY=your_azure_vision_api_key
AZURE_VISION_ENDPOINT=https://your_vision_resource.cognitiveservices.azure.com/vision/v3.2
AZURE_FACE_LIST_SELFIE=user-selfie-faces
AZURE_FACE_LIST_MEDIA=event-media-faces
